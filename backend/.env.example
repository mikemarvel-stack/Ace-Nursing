# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/acenursing?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=acenursing-materials

# AWS Secrets Manager (optional)
# When enabled, secrets are loaded from AWS Secrets Manager and merge into process.env.
# Set USE_AWS_SECRETS=true and provide a secret name.
USE_AWS_SECRETS=false
AWS_SECRETS_NAME=your_secrets_manager_name

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Resend Email
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=orders@acenursing.com
FROM_NAME=AceNursing

# Admin
ADMIN_SETUP_KEY=your_secret_admin_setup_key
