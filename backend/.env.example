# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/acenursing?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ── Cloudflare R2 (recommended) ──────────────────────────────────────────────
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=acenursing-materials
# Set this after enabling public access OR adding a custom domain to your R2 bucket
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── AWS S3 (leave blank if using R2) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# AWS Secrets Manager (optional)
# When enabled, secrets are loaded from AWS Secrets Manager and merge into process.env.
# Set USE_AWS_SECRETS=true and provide a secret name.
USE_AWS_SECRETS=false
AWS_SECRETS_NAME=your_secrets_manager_name

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Resend Email
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=supportacenursing@gmail.com
FROM_NAME=AceNursing

# Tawk.to Live Chat (optional — mirrors contact messages to Tawk.to inbox)
# Get API key: Tawk.to Dashboard → Administration → REST API
# Get Inbox ID: Tawk.to Dashboard → Administration → Inboxes
TAWK_API_KEY=
TAWK_INBOX_ID=

# Admin
ADMIN_EMAIL=supportacenursing@gmail.com
ADMIN_SETUP_KEY=your_secret_admin_setup_key
