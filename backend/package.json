{
  "name": "acenursing-backend",
  "version": "1.0.0",
  "description": "AceNursing API Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:full": "concurrently \"npm run dev\" \"cd ../frontend && npm run dev\"",
    "seed": "node scripts/seed.js",
    "test": "jest",
    "lint": "eslint . --ext .js --ignore-pattern 'node_modules/**' --ignore-pattern 'coverage/**' --ignore-pattern 'scripts/**'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/client-secrets-manager": "^3.1011.0",
    "@aws-sdk/s3-request-presigner": "^3.1011.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "express-request-id": "^1.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "on-finished": "^2.4.1",
    "resend": "^6.9.3",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6",
    "uuid": "^10.0.0",
    "validator": "^13.12.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "fast-xml-parser": ">=5.5.6"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "lines": 35,
        "functions": 18
      }
    },
    "globalSetup": "<rootDir>/jest.globalSetup.js",
    "globalTeardown": "<rootDir>/jest.globalTeardown.js",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  }
}
